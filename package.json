{
  "name": "wealth-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node server.mjs",
    "sync": "node sync-server.mjs",
    "start": "node server.mjs",
    "build": "vite build",
    "build:client": "npm --prefix \"web app cliente\" install && npm --prefix \"web app cliente\" run build && node scripts/copy-client-dist.mjs",
    "build:deploy": "npm run build && npm run build:client",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.7",
    "serverless-http": "^4.0.0",
    "vite": "^5.2.0",
    "xlsx": "^0.18.5"
  }
}
